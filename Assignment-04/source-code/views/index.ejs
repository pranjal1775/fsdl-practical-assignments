<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SecureLife Insurance</title>
  <link rel="stylesheet" href="/style.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>

<nav>
  <div class="container">
    <a href="/" class="nav-brand"><i class="fas fa-shield-alt"></i> SecureLife Insurance</a>
    <ul>
      <li><a href="/" class="active">Home</a></li>
      <li><a href="/policies">Policies</a></li>
      <li><a href="/quote">Get Quote</a></li>
      <li><a href="/admin">Admin</a></li>
    </ul>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="container hero-content">
    <div class="hero-tag"><i class="fas fa-shield-alt"></i> Trusted by 10,000+ Customers</div>
    <h2>Protect What Matters Most</h2>
    <p>Comprehensive insurance solutions for health, life, vehicle, and property — all in one place.</p>
    <div class="hero-actions">
      <a href="/quote" class="btn"><i class="fas fa-file-alt"></i> Get Free Quote</a>
      <a href="/policies" class="btn btn-outline"><i class="fas fa-list"></i> View Policies</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><strong>10K+</strong><span>Happy Customers</span></div>
      <div class="hero-stat"><strong>4</strong><span>Policy Types</span></div>
      <div class="hero-stat"><strong>24/7</strong><span>Support</span></div>
      <div class="hero-stat"><strong>99%</strong><span>Claim Success</span></div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="section" style="background: var(--white);">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">What We Offer</span>
      <h2>Our Insurance Plans</h2>
      <p>Choose from a wide range of plans tailored to your needs</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon" style="background:#dcfce7;color:#16a34a"><i class="fas fa-heartbeat"></i></div>
        <h3>Health Insurance</h3>
        <p>Complete medical coverage for you and your entire family.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#dbeafe;color:#1e40af"><i class="fas fa-user-shield"></i></div>
        <h3>Life Insurance</h3>
        <p>Secure your family's financial future with our life plans.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#fef3c7;color:#d97706"><i class="fas fa-car"></i></div>
        <h3>Vehicle Insurance</h3>
        <p>Protect your car and bike against accidents and theft.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="background:#ede9fe;color:#7c3aed"><i class="fas fa-home"></i></div>
        <h3>Home Insurance</h3>
        <p>Safeguard your property from damage and natural disasters.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background: linear-gradient(135deg,#1e40af,#0ea5e9); color:white; text-align:center;">
  <div class="container">
    <h2 style="font-size:2rem;font-weight:700;margin-bottom:.75rem;">Ready to Get Covered?</h2>
    <p style="opacity:.9;margin-bottom:2rem;">Get a free quote in minutes. No hidden charges.</p>
    <a href="/quote" class="btn"><i class="fas fa-arrow-right"></i> Get Started Now</a>
  </div>
</section>

<footer>
  <p>&copy; 2024 <strong>SecureLife Insurance</strong>. Made with <i class="fas fa-heart"></i> for your protection.</p>
</footer>

</body>
</html>
